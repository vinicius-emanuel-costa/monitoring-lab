# ===========================================
#  Monitoring Lab - Environment Variables
# ===========================================

# Root password for custom containers (mon01, web01, db01, bkp01)
ROOT_PASSWORD=changeme

# MariaDB root password (used by db01 healthcheck)
MYSQL_ROOT_PASSWORD=changeme

# OpenSearch admin password
OPENSEARCH_ADMIN_PASSWORD=changeme

# Timezone
TZ=America/Sao_Paulo
